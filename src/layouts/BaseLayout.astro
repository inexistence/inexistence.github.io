---
import 'animal-island-ui/style';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  bodyClass?: string;
}

const {
  title = 'INEXISTENCE',
  description = '这里收着一些技术笔记、生活碎片，还有舍不得忘记的旧事。',
  image = '/assets/images/cover.jpg',
  noindex = false,
  bodyClass,
} = Astro.props;
const pageTitle = title === 'INEXISTENCE' ? title : `${title} · INEXISTENCE`;
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang="zh-CN" class="js no-js">
  <head>
    <ClientRouter />
    <script is:inline data-astro-rerun>document.documentElement.classList.remove('no-js');</script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="theme-color" content="#8ec7a0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="INEXISTENCE RSS" href="/rss.xml" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{pageTitle}</title>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <SiteHeader />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
    <script is:inline data-astro-rerun>
      (() => {
        let initialized = false;
        let revealTimer;
        let observer;

        const cleanup = () => {
          window.clearTimeout(revealTimer);
          observer?.disconnect();
        };

        const initializeRevealItems = () => {
          if (initialized) return;
          initialized = true;

          revealTimer = window.setTimeout(() => {
            const revealItems = document.querySelectorAll('[data-reveal]');
            if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
              observer = new IntersectionObserver((entries) => {
                for (const entry of entries) {
                  if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                    observer.unobserve(entry.target);
                  }
                }
              }, { threshold: 0.01, rootMargin: '0px 0px -4% 0px' });
              revealItems.forEach((item) => observer.observe(item));
            } else {
              revealItems.forEach((item) => item.classList.add('is-visible'));
            }
          }, 180);
        };

        document.addEventListener('astro:page-load', initializeRevealItems, { once: true });
        window.addEventListener('load', initializeRevealItems, { once: true });
        document.addEventListener('astro:before-swap', cleanup, { once: true });
      })();
    </script>
  </body>
</html>

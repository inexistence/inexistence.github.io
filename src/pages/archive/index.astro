---
import { Divider } from 'animal-island-ui/es/components/Divider/Divider.js';
import { Title } from 'animal-island-ui/es/components/Title/Title.js';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArchiveCollapse from '../../components/ArchiveCollapse';
import { formatDate, getDateParts, getPublishedPosts } from '../../lib/posts';

const posts = await getPublishedPosts();
const grouped = posts.reduce((map, post) => {
  const { year } = getDateParts(post.data.publishDate);
  const entries = map.get(year) ?? [];
  entries.push(post);
  map.set(year, entries);
  return map;
}, new Map<string, typeof posts>());

const groups = [...grouped].map(([year, entries]) => ({
  year,
  posts: entries.map((post) => ({
    title: post.data.title,
    href: `/posts/${post.id}/`,
    date: formatDate(post.data.publishDate),
    publishDate: post.data.publishDate.toISOString(),
    category: post.data.category,
  })),
}));

const newestYear = groups[0]?.year ?? '';
const oldestYear = groups.at(-1)?.year ?? '';
---

<BaseLayout title="文章岛志" description="沿着年份回看 INEXISTENCE 的全部公开文章。">
  <header class="page-hero page-hero--archive">
    <div class="archive-hero__scenery" aria-hidden="true">
      <svg viewBox="0 0 1440 560" preserveAspectRatio="xMidYMid slice" focusable="false">
        <path class="archive-hero__island archive-hero__island--back" d="M790 560C850 437 1009 364 1156 390c134 24 211-60 324-80v250Z" />
        <path class="archive-hero__island archive-hero__island--front" d="M985 560c73-91 184-121 294-95 77 18 132-21 201-50v145Z" />
        <path class="archive-hero__route" d="M900 524c114-53 79-144 184-190 110-48 73-126 184-166 78-28 101-77 172-112" />

        <g class="archive-hero__waypoint" transform="translate(1008 420)">
          <circle r="24" />
          <text text-anchor="middle" dominant-baseline="central">{oldestYear}</text>
        </g>
        <g class="archive-hero__waypoint archive-hero__waypoint--current" transform="translate(1193 245)">
          <circle r="28" />
          <text text-anchor="middle" dominant-baseline="central">{newestYear}</text>
        </g>

        <g class="archive-hero__leaf" transform="translate(1360 92) rotate(-24)">
          <path d="M0 27C2 9 15-1 35 0c-1 20-12 31-35 27Z" />
          <path d="M4 23 29 5" />
        </g>
        <g class="archive-hero__leaf archive-hero__leaf--small" transform="translate(928 474) rotate(36)">
          <path d="M0 22C2 8 12 0 28 0c0 16-9 25-28 22Z" />
          <path d="M4 19 23 4" />
        </g>
      </svg>
    </div>
    <div class="shell page-hero__inner" data-reveal>
      <p class="eyebrow">ARCHIVE TRAIL</p>
      <h1>沿着时间的小径</h1>
      <p>{posts.length} 篇公开文字，散落在 {groups.length} 个年份里。</p>
    </div>
  </header>

  <section class="archive shell section">
    <div class="archive__desktop">
      {groups.map((group) => (
        <section class="archive-year" data-reveal>
          <div class="archive-year__label">
            <h2><Title size="large" color="app-teal">{group.year}</Title></h2>
            <span>{group.posts.length} 篇</span>
          </div>
          <ol>
            {group.posts.map((post) => (
              <li>
                <time datetime={post.publishDate}>{post.date}</time>
                <a href={post.href}>{post.title}</a>
                <span>{post.category}</span>
              </li>
            ))}
          </ol>
          <Divider type="dashed-brown" />
        </section>
      ))}
    </div>
    <div class="archive__mobile">
      <ArchiveCollapse client:visible groups={groups} />
    </div>
  </section>
</BaseLayout>

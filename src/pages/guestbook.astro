---
import { Card } from 'animal-island-ui/es/components/Card/Card.js';
import { Divider } from 'animal-island-ui/es/components/Divider/Divider.js';
import { Tag } from 'animal-island-ui/es/components/Tag/Tag.js';
import BaseLayout from '../layouts/BaseLayout.astro';
import Waline from '../components/Waline.astro';
---

<BaseLayout title="岛屿留言板" description="在 INEXISTENCE 留下一句话，或与路过这里的岛民聊聊。">
  <header class="page-hero guestbook-hero">
    <div class="shell page-hero__inner" data-reveal>
      <p class="eyebrow">GUESTBOOK</p>
      <h1>留下一个脚印</h1>
      <p>如果这座小岛让你想起什么，欢迎留下一句话。</p>
    </div>
  </header>

  <section class="guestbook section shell" aria-labelledby="guestbook-title">
    <div class="guestbook__heading" data-reveal>
      <Tag size="medium" variant="soft" color="app-teal">岛民留言</Tag>
      <div>
        <h2 id="guestbook-title">慢慢聊，不着急</h2>
        <p>留下昵称和邮箱就能说话；邮箱不会公开，只用来识别你的留言身份。</p>
      </div>
    </div>

    <div class="guestbook__divider" aria-hidden="true"><Divider type="wave-yellow" /></div>

    <div class="guestbook__comments" data-reveal>
      <Card className="waline-card">
        <Waline path="/guestbook/" label="留言板" />
      </Card>
    </div>
  </section>
</BaseLayout>

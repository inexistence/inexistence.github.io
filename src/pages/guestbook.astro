---
import { Card } from 'animal-island-ui/es/components/Card/Card.js';
import BaseLayout from '../layouts/BaseLayout.astro';
import Waline from '../components/Waline.astro';
---

<BaseLayout title="岛屿留言板" description="在 INEXISTENCE 留下一句话，或与路过这里的岛民聊聊。">
  <header class="page-hero page-hero--scene guestbook-hero">
    <div class="shell page-hero__inner page-hero__inner--scene">
      <div class="page-hero__copy guestbook-hero__copy">
        <p class="eyebrow" data-reveal>GUESTBOOK</p>
        <h1 data-reveal>留下一个脚印</h1>
        <p data-reveal>写下想说的话，和路过这里的岛民打个招呼。</p>
      </div>
      <img
        class="page-hero__scene guestbook-hero__scene"
        src="/assets/page-scenes/guestbook/message-corner-scene-v2.webp"
        alt=""
        aria-hidden="true"
        data-reveal
      />
    </div>
  </header>

  <section class="guestbook section shell" aria-label="岛民留言">
    <div class="guestbook__comments" data-reveal>
      <Card className="waline-card">
        <Waline
          path="/guestbook/"
          label="留言板"
          emailHint="不会公开，仅用于识别留言身份"
        />
      </Card>
    </div>
  </section>
</BaseLayout>

---
import { Card } from 'animal-island-ui/es/components/Card/Card.js';
import BaseLayout from '../layouts/BaseLayout.astro';
import Waline from '../components/Waline.astro';
---

<BaseLayout title="岛屿留言板" description="在 INEXISTENCE 留下一句话，或与路过这里的岛民聊聊。">
  <header class="page-hero guestbook-hero">
    <div class="shell page-hero__inner" data-reveal>
      <p class="eyebrow">GUESTBOOK</p>
      <h1>留下一个脚印</h1>
      <p>写下想说的话，和路过这里的岛民打个招呼。</p>
    </div>
    <img
      class="guestbook-hero__scene"
      src="/assets/blog-images/guestbook/message-corner-scene.png"
      alt=""
      aria-hidden="true"
    />
  </header>

  <section class="guestbook section shell" aria-label="岛民留言">
    <div class="guestbook__comments" data-reveal>
      <Card className="waline-card">
        <Waline
          path="/guestbook/"
          label="留言板"
          emailHint="不会公开，仅用于识别留言身份"
        />
      </Card>
    </div>
  </section>
</BaseLayout>

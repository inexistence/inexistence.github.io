---
import { Button } from 'animal-island-ui/es/components/Button/Button.js';
import { Card } from 'animal-island-ui/es/components/Card/Card.js';
import { Divider } from 'animal-island-ui/es/components/Divider/Divider.js';
import { Loading } from 'animal-island-ui/es/components/Loading/Loading.js';
import { Tag } from 'animal-island-ui/es/components/Tag/Tag.js';
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Waline from '../../components/Waline.astro';
import { categoryColor, formatDate, getPublishedPosts, type Post } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      newer: index > 0 ? posts[index - 1] : null,
      older: index < posts.length - 1 ? posts[index + 1] : null,
    },
  }));
}

interface Props {
  post: Post;
  newer: Post | null;
  older: Post | null;
}

const { post, newer, older } = Astro.props;
const { Content, headings } = await render(post);
const color = categoryColor(post.data.category);
const tocHeadings = headings.filter((heading) => heading.depth <= 3);
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.cover || undefined}>
  <article class="post">
    <header class:list={['post-header', `post-header--${color}`]}>
      <div class="shell post-header__inner" data-reveal>
        <a class="post-header__back" href="/archive/">← 返回岛志</a>
        <div class="post-header__content">
          <div class="post-header__meta">
            <a href={`/category/${encodeURIComponent(post.data.category)}/`}>
              <Tag size="medium" variant="solid" color={color}>{post.data.category}</Tag>
            </a>
            <time datetime={post.data.publishDate.toISOString()}>{formatDate(post.data.publishDate)}</time>
            {post.data.place && <span>{post.data.place}</span>}
          </div>
          <h1>{post.data.title}</h1>
          <p>{post.data.description}</p>
        </div>
      </div>
    </header>

    <div class="post-layout shell">
      <div class="post-layout__main">
        {post.data.cover && (
          <figure class="post-cover" data-reveal>
            <img src={post.data.cover} alt={`${post.data.title}的文章封面`} />
          </figure>
        )}
        <div class="prose" data-reveal>
          <Content />
        </div>
      </div>

      {tocHeadings.length > 2 && (
        <aside class="post-toc" aria-label="文章目录" data-post-toc>
          <p>沿途路标</p>
          <ol>
            {tocHeadings.map((heading) => (
              <li class:list={[`depth-${heading.depth}`]}><a href={`#${heading.slug}`} data-toc-link>{heading.text}</a></li>
            ))}
          </ol>
        </aside>
      )}
    </div>

    <div class="shell"><Divider type="wave-yellow" /></div>

    <section class="post-comments shell" aria-labelledby="post-comments-title" data-reveal>
      <div class="post-comments__heading">
        <Tag size="medium" variant="soft" color="app-green">岛民留言</Tag>
        <div>
          <h2 id="post-comments-title">聊聊这篇</h2>
          <p>欢迎留下想法。邮箱不会公开，只用来识别你的留言身份。</p>
        </div>
      </div>
      <Card className="waline-card">
        <Waline path={`/posts/${post.id}/`} label={`${post.data.title}的评论区`} />
      </Card>
    </section>

    <nav class="post-nav shell" aria-label="文章翻页">
      <div>
        {newer && (
          <form action={`/posts/${newer.id}/`}>
            <span>更新一篇</span>
            <Button type="default" size="large" htmlType="submit">← {newer.data.title}</Button>
          </form>
        )}
      </div>
      <div>
        {older && (
          <form action={`/posts/${older.id}/`}>
            <span>更早一篇</span>
            <Button type="default" size="large" htmlType="submit">{older.data.title} →</Button>
          </form>
        )}
      </div>
    </nav>

    <a class="back-to-top" href="#main-content" aria-label="返回文章顶部" data-back-to-top>
      <span class="back-to-top__island-scene" aria-hidden="true">
        <Loading client:idle active={true} className="back-to-top__island" />
      </span>
      <span class="back-to-top__label">回到顶部</span>
    </a>
  </article>

  <script is:inline data-astro-rerun>
    (() => {
      const backToTop = document.querySelector('[data-back-to-top]');
      const postHeader = document.querySelector('.post-header');
      const siteFooter = document.querySelector('.site-footer');
      const postToc = document.querySelector('[data-post-toc]');

      if (!backToTop || !postHeader) return;

      let scrollIdleTimer;
      let lastScrollY = window.scrollY;
      const tocLinks = postToc ? [...postToc.querySelectorAll('[data-toc-link]')] : [];
      const tocHeadings = tocLinks
        .map((link) => document.getElementById(decodeURIComponent(link.hash.slice(1))))
        .filter(Boolean);
      let activeTocLink;
      let tocFrame;
      let tocNavigationTimer;
      let isTocNavigationInProgress = false;

      const setActiveTocLink = (nextActiveLink) => {
        if (!nextActiveLink || nextActiveLink === activeTocLink) return;

        activeTocLink?.classList.remove('is-active');
        activeTocLink?.removeAttribute('aria-current');
        nextActiveLink.classList.add('is-active');
        nextActiveLink.setAttribute('aria-current', 'location');
        activeTocLink = nextActiveLink;
      };

      const syncActiveTocLink = () => {
        if (!tocHeadings.length) return;

        const activeHeading = tocHeadings.reduce((currentHeading, heading) => (
          heading.getBoundingClientRect().top <= 128 ? heading : currentHeading
        ), tocHeadings[0]);
        const nextActiveLink = tocLinks[tocHeadings.indexOf(activeHeading)];

        setActiveTocLink(nextActiveLink);
      };

      const requestTocSync = () => {
        if (tocFrame) return;
        tocFrame = window.requestAnimationFrame(() => {
          tocFrame = undefined;
          syncActiveTocLink();
        });
      };

      const completeTocNavigation = () => {
        window.clearTimeout(tocNavigationTimer);
        tocNavigationTimer = window.setTimeout(() => {
          isTocNavigationInProgress = false;
          syncActiveTocLink();
        }, 180);
      };

      const syncInteractiveState = () => {
        const isInteractive = backToTop.classList.contains('is-visible')
          && !backToTop.classList.contains('is-near-footer');
        backToTop.setAttribute('aria-hidden', String(!isInteractive));
        if (isInteractive) {
          backToTop.removeAttribute('tabindex');
        } else {
          backToTop.setAttribute('tabindex', '-1');
        }
      };

      const setVisibility = (isVisible) => {
        backToTop.classList.toggle('is-visible', isVisible);
        syncInteractiveState();
      };

      const observer = new IntersectionObserver(([entry]) => {
        setVisibility(!entry.isIntersecting && entry.boundingClientRect.bottom < 0);
      });
      observer.observe(postHeader);

      let footerObserver;
      if (siteFooter) {
        footerObserver = new IntersectionObserver(([entry]) => {
          const isNearFooter = entry.isIntersecting;
          backToTop.classList.toggle('is-near-footer', isNearFooter);
          syncInteractiveState();
        }, { rootMargin: '0px 0px 72px 0px' });
        footerObserver.observe(siteFooter);
      }

      const handleScroll = () => {
        const currentScrollY = window.scrollY;
        const scrollDelta = currentScrollY - lastScrollY;

        if (Math.abs(scrollDelta) >= 8) {
          backToTop.classList.toggle('is-expanded', scrollDelta < 0);
          lastScrollY = currentScrollY;
        }

        window.clearTimeout(scrollIdleTimer);
        scrollIdleTimer = window.setTimeout(() => {
          if (document.activeElement !== backToTop && !backToTop.matches(':hover')) {
            backToTop.classList.remove('is-expanded');
          }
        }, 2000);
        if (isTocNavigationInProgress) {
          completeTocNavigation();
        } else {
          requestTocSync();
        }
      };
      window.addEventListener('scroll', handleScroll, { passive: true });
      window.addEventListener('resize', requestTocSync);

      postToc?.addEventListener('click', (event) => {
        const target = event.target.closest('[data-toc-link]');
        if (!target) return;

        isTocNavigationInProgress = true;
        setActiveTocLink(target);
        completeTocNavigation();
      });

      backToTop.addEventListener('focus', () => {
        backToTop.classList.add('is-expanded');
      });

      backToTop.addEventListener('blur', () => {
        if (!backToTop.matches(':hover')) {
          backToTop.classList.remove('is-expanded');
        }
      });

      backToTop.addEventListener('click', (event) => {
        event.preventDefault();
        window.scrollTo({
          top: 0,
          behavior: window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 'auto' : 'smooth',
        });
      });

      syncInteractiveState();
      syncActiveTocLink();
      document.addEventListener('astro:before-swap', () => {
        observer.disconnect();
        footerObserver?.disconnect();
        window.clearTimeout(scrollIdleTimer);
        window.clearTimeout(tocNavigationTimer);
        if (tocFrame) window.cancelAnimationFrame(tocFrame);
        window.removeEventListener('scroll', handleScroll);
        window.removeEventListener('resize', requestTocSync);
      }, { once: true });
    })();
  </script>
</BaseLayout>

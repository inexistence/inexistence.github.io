---
import leafIcon from '../../node_modules/animal-island-ui/dist/files/icon-leaf.40329f03.png';

const path = Astro.url.pathname;
const links = [
  { href: '/', label: '岛屿' },
  { href: '/archive/', label: '岛志' },
  { href: '/rss.xml', label: 'RSS' },
];
---

<header class="site-header">
  <a class="site-mark" href="/" aria-label="INEXISTENCE 首页">
    <span class="site-mark__leaf" aria-hidden="true">
      <svg viewBox="0 0 87 83" focusable="false">
        <mask id="site-mark-leaf-mask" maskUnits="userSpaceOnUse" x="0" y="0" width="87" height="83" style="mask-type: luminance">
          <image href={leafIcon.src} width="87" height="83" />
        </mask>
        <rect width="87" height="83" fill="currentColor" mask="url(#site-mark-leaf-mask)" />
      </svg>
    </span>
    <span>INEXISTENCE</span>
  </a>
  <nav aria-label="主导航">
    <ul class="site-nav">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={link.href === '/' ? (path === '/' ? 'page' : undefined) : (path.startsWith(link.href) ? 'page' : undefined)}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

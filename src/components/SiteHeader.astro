---
const path = Astro.url.pathname;
const links = [
  { href: '/', label: '岛屿' },
  { href: '/archive/', label: '归档' },
  { href: '/rss.xml', label: 'RSS' },
];
---

<header class="site-header">
  <a class="site-mark" href="/" aria-label="INEXISTENCE 首页">
    <span class="site-mark__leaf" aria-hidden="true">
      <svg viewBox="0 0 64 64" focusable="false">
        <path class="site-mark__leaf-blade" d="M47 13C29 15 17 25 16 40c8-5 16-8 25-9-8 4-14 9-19 16 17 2 29-9 25-34Z" />
        <path class="site-mark__leaf-vein" d="M14 50c8-10 18-19 31-27" />
      </svg>
    </span>
    <span>INEXISTENCE</span>
  </a>
  <nav aria-label="主导航">
    <ul class="site-nav">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            aria-current={link.href === '/' ? (path === '/' ? 'page' : undefined) : (path.startsWith(link.href) ? 'page' : undefined)}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
